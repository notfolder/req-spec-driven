# Neon PostgreSQL 外部DB接続設定
# 実際の接続文字列を .env に設定してください（このファイルはダミー値のみ）

# Neon PostgreSQL への接続文字列
# 形式: postgresql://ユーザー名:パスワード@ホスト/DB名?sslmode=require&channel_binding=require
EXTERNAL_DB_URL=postgresql://your_user:your_password@your-host.neon.tech/your_db?sslmode=require&channel_binding=require

# モックモード切替（true: モック使用、false: 実DB接続）
MOCK_EXTERNAL_DB=true
